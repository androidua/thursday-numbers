/*
  # Prevent clickjacking — deny all iframe embedding
  X-Frame-Options: DENY

  # Prevent MIME-type sniffing — always use declared Content-Type
  X-Content-Type-Options: nosniff

  # Referrer policy — only send origin on cross-origin requests
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser feature/API access to only what the app needs
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), fullscreen=()

  # Content Security Policy
  # - script-src: local JS + Chart.js CDN only
  # - style-src:  local CSS only (no inline styles in use)
  # - img-src:    local + data URI (emoji favicon)
  # - connect-src: local fetch() calls only (draws JSON, picks JSON, VERSION)
  # - object-src: explicit deny (redundant with default-src 'none' but auditor-friendly)
  # - frame-ancestors: deny all iframing (duplicates X-Frame-Options for modern browsers)
  Content-Security-Policy: default-src 'none'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self'; img-src 'self' data:; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

  # HTTPS enforcement (supplementary — Cloudflare also enforces this at the edge)
  # preload: submittable to hstspreload.org for browser-native HSTS preloading
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Cross-origin isolation (defence-in-depth — CSP already blocks most attack surface)
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Long-lived cache for static JS/CSS (served via Cloudflare edge; can be purged on redeploy)
/app.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/style.css
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Short cache + SWR for JSON data — draw file updates weekly, SWR keeps visitors fast
/data/*.json
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

/picks/*.json
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

# VERSION file — short cache so deploys surface quickly in the footer
/VERSION
  Cache-Control: public, max-age=60

# OG images — long cache; filename changes when image regenerates
/og-image.*
  Cache-Control: public, max-age=604800
